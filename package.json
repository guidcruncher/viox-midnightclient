{
  "name": "viox-midnightclient",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "VIOX Music Server Web Client",
  "keywords": "viox,client",
  "homepage": "https://github.com/guidcruncher/viox-midnightclient",
  "author": "John Crocker <182365840+guidcruncher@users.noreply.github.com> (https://linktr.ee/johncrocker)",
  "funding": "https://buymeacoffee.com/guidcruncher",
  "scripts": {
    "docker": "make dev",
    "dev": "pnpm run format && vite --host",
    "db": "sudo sqlite3 ../run/data/datastore.db",
    "build": "vue-tsc -b && vite build --mode development",
    "build:prod": "NODE_ENV=production vue-tsc -b && vite build --mode production",
    "preview": "vite preview",
    "format": "prettier --config ./.prettierrc --write src/",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "tidy": "pnpm run format && pnpm run lint:fix && knip --config ./knip.json",
    "tidy:write": "knip --fix --config ./knip.json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "axios": "^1.15.1",
    "lucide-vue-next": "^1.0.0",
    "mitt": "^3.0.1",
    "qs": "^6.15.1",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/qs": "^6.15.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "fast-glob": "^3.3.3",
    "globals": "^17.5.0",
    "knip": "^6.6.0",
    "prettier": "^3.8.3",
    "tailwind-scrollbar-hide": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.9",
    "vue-tsc": "^3.2.7"
  }
}
