{
  "name": "viox-midnightclient",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run format && vite --host",
    "build": "vue-tsc -b && vite build --mode development",
    "build:prod": "NODE_ENV=production vue-tsc -b && vite build --mode production",
    "preview": "vite preview",
    "format": "prettier --config ./.prettierrc --write src/",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "tidy": "npm run format && npm run lint:fix && knip --config ./knip.json",
    "tidy:write": "knip --fix --config ./knip.json"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "lucide-vue-next": "^1.0.0",
    "qs": "^6.15.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.15.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "knip": "^6.1.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  }
}
